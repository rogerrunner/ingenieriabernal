{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "redirects": [
    { "source": "/ingenieria-hidraulica-manizales",    "destination": "/ingenieria-manizales",                   "permanent": true },
    { "source": "/ingenieria-hidraulica-eje-cafetero", "destination": "/ingenieria-eje-cafetero",                "permanent": true },
    { "source": "/ingenieria-hidraulica-bogota",       "destination": "/ingenieria-bogota",                      "permanent": true },
    { "source": "/ingenieria-hidraulica-medellin",     "destination": "/ingenieria-medellin",                    "permanent": true },
    { "source": "/ingenieria-hidraulica-cali",         "destination": "/ingenieria-cali",                        "permanent": true },
    { "source": "/ingenieria-hidraulica-pereira",      "destination": "/regional/pereira",                       "permanent": true },
    { "source": "/ingenieria-hidraulica-armenia",      "destination": "/regional/armenia",                       "permanent": true },
    { "source": "/hec-ras-modelacion-hidraulica",      "destination": "/servicios/modelacion-hec-ras",           "permanent": true },
    { "source": "/diseno-hidrosanitario-nsr10",        "destination": "/servicios/redes-hidrosanitarias",        "permanent": true },
    { "source": "/estudios-inundacion-colombia",       "destination": "/servicios/estudios-hidrologicos",        "permanent": true },
    { "source": "/acueductos-alcantarillados",         "destination": "/servicios/acueducto-alcantarillado",     "permanent": true },
    { "source": "/regalias-mga-web",                   "destination": "/servicios/regalias-mga",                 "permanent": true }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
